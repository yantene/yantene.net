{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "pnpm",
      "args": [
        "dlx",
        "chrome-devtools-mcp@0.13.0",
        "--headless",
        "--executablePath",
        "/usr/bin/chromium",
        "--isolated",
        "--chromeArg=--no-sandbox",
        "--chromeArg=--disable-setuid-sandbox"
      ]
    }
  }
}
