mixin title(post, index, class_name)
  if post.link
    h1(itemprop="name")
      a(class=class_name, href=url_for(post.link), target="_blank", itemprop="url")= post.title
  else if post.title
    if index
      h1(itemprop="name")
        a(class=class_name, href=url_for(post.link))= post.title
    else
      h1(class=class_name, itemprop="name")= post.title
