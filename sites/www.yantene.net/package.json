{
  "private": true,
  "name": "www.yantene.net",
  "version": "0.1.3",
  "scripts": {
    "build:production": "npx env-cmd -f .env.production next build",
    "build:staging": "npx env-cmd -f .env.staging next build",
    "dev": "next dev",
    "format": "run-s -c format:*",
    "format:next": "next lint --fix",
    "format:prettier": "prettier --write .",
    "format:prettier-package-json": "prettier-package-json --success --write ./package.json",
    "lint": "run-s -c lint:*",
    "lint:next": "next lint",
    "lint:prettier": "prettier --check .",
    "lint:prettier-package-json": "prettier-package-json --success --list-different ./package.json",
    "start": "next start",
    "test": "jest"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^9.7.1",
    "@vanilla-extract/css": "^1.13.0",
    "eslint-config-next": "13.5.4",
    "jotai": "^2.4.3",
    "next": "13.5.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-icons": "^4.11.0",
    "typescript": "5.2.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.2",
    "@types/react": "^18.2.24",
    "@types/react-dom": "^18.2.8",
    "@types/react-icons": "^3.0.0",
    "@vanilla-extract/next-plugin": "^2.3.1",
    "env-cmd": "^10.1.0",
    "eslint": "^8.50.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^17.1.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.28.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.3",
    "prettier-package-json": "^2.8.0"
  }
}
