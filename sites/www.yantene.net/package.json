{
  "private": true,
  "name": "www.yantene.net",
  "version": "0.1.0",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "format": "run-s -c format:*",
    "format:next": "next lint --fix",
    "format:prettier": "prettier --write .",
    "format:prettier-package-json": "prettier-package-json --success --write ./package.json",
    "lint": "run-s -c lint:*",
    "lint:next": "next lint",
    "lint:prettier": "prettier --check .",
    "lint:prettier-package-json": "prettier-package-json --success --list-different ./package.json",
    "start": "next start",
    "test": "jest"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^9.7.1",
    "@types/node": "20.6.3",
    "@types/react": "18.2.22",
    "@types/react-dom": "18.2.7",
    "autoprefixer": "10.4.16",
    "eslint": "8.49.0",
    "eslint-config-next": "13.5.2",
    "next": "13.5.2",
    "postcss": "8.4.30",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.3.3",
    "typescript": "5.2.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.3",
    "@testing-library/react": "^14.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.0.3",
    "prettier-package-json": "^2.8.0"
  }
