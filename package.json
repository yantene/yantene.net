{
  "private": true,
  "name": "yantene.net",
  "version": "0.0.1",
  "description": "yantene.net",
  "license": "UNLICENSED",
  "author": "Shuhei YOSHIDA <contact@yantene.net> (https://www.yantene.net/)",
  "homepage": "https://github.com/yantene/yantene.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yantene/yantene.net.git"
  },
  "bugs": {
    "url": "https://github.com/yantene/yantene.net/issues"
  },
  "scripts": {
    "format": "run-s -c format:*",
    "format:api.www.yantene.net": "npm run --workspace api.www.yantene.net format",
    "format:prettier": "prettier --write .",
    "format:prettier-package-json": "prettier-package-json --success --write .{,/api.www.yantene.net,/www.yantene.net}/package.json",
    "format:www.yantene.net": "npm run --workspace www.yantene.net format",
    "postinstall": "node -e \"if (process.env.NODE_ENV !== 'production'){process.exit(1)} \" || husky install",
    "lint": "run-s -c lint:*",
    "lint:api.www.yantene.net": "npm run --workspace api.www.yantene.net lint",
    "lint:prettier": "prettier --check .",
    "lint:prettier-package-json": "prettier-package-json --success --list-different .{,/api.www.yantene.net,/www.yantene.net}/package.json",
    "lint:www.yantene.net": "npm run --workspace www.yantene.net lint"
  },
  "workspaces": {
    "packages": [
      "www.yantene.net",
      "api.www.yantene.net"
    ]
  },
  "dependencies": {
    "@fastify/static": "^6.6.0",
    "npm-run-all": "^4.1.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "husky": "^8.0.1",
    "prettier": "^2.7.1",
    "prettier-package-json": "^2.7.0"
  }
}
